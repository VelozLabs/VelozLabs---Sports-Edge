# BaseballIQ — Environment Variables
# Copy this file to .env and fill in your values
# cp .env.example .env

# Required for LLM enrichment and live scouting reports
# Get a free API key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Set to 1 to skip live data ingestion (uses existing Bronze/Gold files)
DEMO_MODE=0
