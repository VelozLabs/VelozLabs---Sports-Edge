# BaseballIQ — Environment Variables
# Copy this file to .env and fill in your values
# cp .env.example .env

# Required for LLM enrichment and live scouting reports
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Required for live HR prop lines (The Odds API — player props tier)
ODDS_API_KEY=your-odds-api-key-here

# Set to 1 to skip live data ingestion (uses existing Bronze/Gold files)
DEMO_MODE=0
